{
  "name": "n8n-nodes-modern-treasury",
  "version": "1.0.0",
  "description": "n8n community node for Modern Treasury payment operations - ACH, wire transfers, RTP, counterparty management, and treasury automation",
  "keywords": [
    "n8n-community-node-package",
    "modern-treasury",
    "ach",
    "payments",
    "wire",
    "treasury",
    "rtp",
    "banking",
    "fintech",
    "payment-operations"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://velobpa.com",
  "author": {
    "name": "Velocity BPA",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-modern-treasury.git"
  },
  "engines": {
    "node": ">=18.10",
    "pnpm": ">=9.1"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "index.js",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "pnpm build && pnpm lint -c .eslintrc.prepublish.js nodes credentials package.json",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ModernTreasuryApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ModernTreasury/ModernTreasury.node.js",
      "dist/nodes/ModernTreasury/ModernTreasuryTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}